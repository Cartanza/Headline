<section class="gh-topic gh-topic-minimal">
    <header class="gh-topic-header">
        <h2 class="gh-topic-name">
            <a href="/{{slug}}">{{name}}</a>
        </h2>
        <a class="gh-topic-link" href="/{{slug}}">More {{> partials/icons/arrow}}</a>
    </header>

    <div class="gh-topic-content">
        {{#get "posts" include="tags,authors" filter="tag:{{slug}}" limit="5"}}
            {{#foreach posts}}
                {{> partials/loop-minimal}}
            {{/foreach}}
        {{/get}}
    </div>
</section>